.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Project-specific
*.db
*.sqlite
*.sqlite3
db/
!db/.gitkeep

# Demo DB exception — allow prebuilt demo database files
!demo/aip_demo/db/*.db
!demo/aip_demo/db/

# Secrets / local config
.env
*.local.toml
config/local*.toml

# Test / tool caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.nox/
.tox/
htmlcov/
.coverage

# SQLite runtime files
*.db-journal
*.db-wal
*.db-shm

# Logs and temp
*.log
tmp/
temp/

# AI session artifacts — never commit agent scratchpads
WORKLOG.md
CLEANUP_BASELINE.md
PHASE*_HANDOFF_PROMPT.md

# Data folders - ignore contents but keep structure
archive/*
!archive/.gitkeep
import/*
!import/.gitkeep
failed/*
!failed/.gitkeep
logs/*
!logs/.gitkeep
config/selected_models.json
config/slot_models.json
config/aip.config.toml
config/*.toml
