# AIP_Brain Environment Configuration
# Copy this file to .env and fill in your API key.
# NEVER commit the .env file with real API keys.

# OpenRouter API Key — used by ALL model slots (synthesis, evaluation, sexton, embedding)
# Get your key at https://openrouter.ai/keys
AIP_OPENAI_API_KEY=sk-or-v1-YOUR_KEY_HERE

# AIP Backend URL (FastAPI server)
AIP_BACKEND_URL=http://127.0.0.1:8000

# NiceGUI frontend port
AIP_GUI_PORT=8080
