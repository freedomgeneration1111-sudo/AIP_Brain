# AIP Configuration Example
#
# Copy this file to `config/aip.config.toml` and customize for your environment.
# This is a SAFE template — all secrets (API keys, passwords) are set to empty
# and MUST be provided via environment variables instead:
#   AIP_SYNTHESIS_API_KEY, AIP_EVALUATION_API_KEY, etc.
#
# Do NOT commit real keys. The live `config/aip.config.toml` is (or should be)
# ignored by .gitignore.
#
# Model names, hosts, ports, limits, and other non-secret values are shown
# as working laptop-profile examples. Adjust for production as needed.
# See ROADMAP.md, STATUS.md, and docs/ for context on phases and features.

[retrieval]
confidence_threshold = 0.3
weight_semantic = 0.6
weight_recency = 0.15
weight_authority = 0.15
weight_frequency = 0.1

[embedding]
provider = "openai_compatible"
model = "text-embedding-3-small"
base_url = "https://openrouter.ai/api"
# api_key provided via env (AIP_EMBEDDING_API_KEY or similar)

[sexton]
classification_batch_size = 50
classification_interval_seconds = 300
audit_on_slot_change = true
max_unclassified_before_alert = 10
# Graph extraction batching (graduated Sprint 5.21).
graph_extraction_batch_enabled = true
graph_extraction_batch_size = 2  # Conservative default; increase to 4-6 for larger corpora
# Batch size auto-tuning (graduated to default-on Sprint 5.24).
# Dynamically adjusts batch_size based on parse failure rate.
# Decreases on high failures, increases when consistently successful.
graph_extraction_batch_auto_tune_enabled = true
graph_extraction_batch_size_min = 1
graph_extraction_batch_size_max = 8
graph_extraction_auto_tune_window = 5  # Number of batches to consider
graph_extraction_auto_tune_decrease_threshold = 0.3  # Failure rate above → decrease
graph_extraction_auto_tune_increase_threshold = 0.1  # Failure rate below → increase

[ace_playbook]
db_path = "db/ace_playbook.db"
auto_derive = true
min_confidence = 0.7

[router]
default_exploration_weight = 0.1
min_sample_count = 10
weight_decay = 0.95

[router.domain_overrides]

[budget]
session_token_limit = 500000
project_token_limit = 5000000
daily_token_limit = 10000000
budget_warning_threshold = 0.8
budget_hard_stop = true

[beast]
corpus_reindex_interval_seconds = 3600
entity_maintenance_interval_seconds = 1800
health_check_interval_seconds = 60
max_reindex_batch_size = 1000

[api]
host = "127.0.0.1"
port = 8000
cors_origins = ["http://localhost:3000"]
workers = 1
chat_max_history_turns = 50
review_page_size = 20
artifact_page_size = 20

[cli]
color = true
pager = true
output_format = "table"

[mcp]
enabled = true
transport = "stdio"
max_concurrent_tools = 5

[chat]
system_prompt_path = "prompts/chat_system.md"
max_context_turns = 50
auto_summarize_at = 40

[autonomy]
default_level = "read"
escalation_requires_definer = true
audit_retention_days = 90
model_gen_assumption = "Models should not autonomously escalate to admin actions"

[lexical]
db_path = "db/lexical.db"
fts5_tokenizer = "unicode61"

[knowledge]
compilation_model_slot = "synthesis"
evaluation_model_slot = "evaluation"
max_source_canonicals = 10
compilation_confidence_threshold = 0.6
auto_index_on_approval = true
model_gen_assumption = "Synthesis model can reliably produce structured knowledge summaries from multiple canonical sources"

[plugins]
plugins_dir = "plugins"
enabled = true
auto_discover = true
sandbox_mode = true
model_gen_assumption = "Plugins provide extensibility for model providers beyond built-in slots"

[collaborators]
enabled = false
max_collaborators = 5
collaborator_can_create_drafts = true
collaborator_can_submit_review = true
collaborator_can_approve = false
readonly_can_search = true

[performance]
profiling_enabled = false
max_memory_mb = 4096
retrieval_timeout_seconds = 30.0
batch_embed_size = 32
sqlite_wal_mode = true
sqlite_busy_timeout_ms = 5000
vector_query_limit = 50
fts5_query_limit = 50

[release]
release_version = "0.1.0"
release_date = ""
release_status = "alpha"
architecture_revision = "5.2"

[review]
faithfulness_threshold = 0.85
domain_coherence_threshold = 0.8
require_definer_approval = true
auto_promote_on_approval = false

[workflow]
default_template = "workflow_01"
max_parallel_nodes = 3
context_reset_turn_threshold = 40

[ecs]
db_path = "db/ecs.db"
transition_audit_enabled = true

[trajectory]
loop_detection_window = 5
anxiety_threshold = 0.7
failure_streak_threshold = 3
context_reset_on_anxiety = true

[evaluation]
faithfulness_threshold = 0.85
domain_coherence_threshold = 0.8
adversarial_enabled = false

[vigil]
canonical_health_check_interval_seconds = 3600
stale_threshold_days = 30
re_evaluate_on_slot_change = true
max_re_evaluate_batch_size = 50
entity_consistency_check = true
# LLM-powered faithfulness evaluation (graduated to default-on Sprint 5.24).
# Uses the "evaluation" model slot to check whether responses accurately
# reflect retrieved sources. Graceful fallback to pure-Python heuristic
# checks (citation rate, numeric grounding, hedging) when model unavailable.
llm_faithfulness_enabled = true
llm_faithfulness_model_slot = "evaluation"
llm_faithfulness_sample_size = 10  # Max turns per cycle for LLM evaluation

[auth]
auth_enabled = false
session_timeout_seconds = 86400
api_key_enabled = ""  # Set via environment variable
bcrypt_rounds = 12
definer_identity = "definer"

[rate_limit]
enabled = true
requests_per_minute = 60
burst_size = 10

[rate_limit.per_endpoint_overrides]
model_budget_protection = true

[canonical_pipeline]
faithfulness_threshold = 0.85
domain_coherence_threshold = 0.8
require_vigil_health_check = true
indexing_enabled = true
require_definer_approval = true

[deployment]
profile_name = "laptop"
vector_backend = "sqlite_vss"
model_provider = "ollama"
auth_enabled = false
workers = 1
memory_limit_mb = 4096

[database]
db_path = "db/state.db"

# Read pool sizing for SQLite WAL mode stores (lexical, vector, graph, corpus_turn).
# Pool auto-sizing can automatically increase pool_size when exhaustion_rate
# is sustained high, with safeguards (max cap, logged changes, rollback).
[read_pool]
pool_size = 3  # Default pool size for all stores
auto_apply_enabled = true  # Sprint 5.24: auto-apply pool size increases (with safeguards)
auto_apply_consecutive_threshold = 5  # Observations of high exhaustion before auto-applying
auto_apply_max_increase = 4  # Maximum total connections that can be auto-added above configured
auto_apply_max_pool = 12  # Absolute maximum pool size (safeguard cap)

# Per-store overrides (uncomment and adjust as needed)
# [read_pool.stores.graph_store]
# pool_size = 5
# [read_pool.stores.vector_store]
# pool_size = 4

[vector_backend]
provider = "pgvector"
host = "127.0.0.1"
port = 5432

[models]
ci_mode = false

[models.synthesis]
provider = "openai_compatible"
model = "google/gemma-3-4b-it"
base_url = "https://openrouter.ai/api"
# api_key = ""  # Set via AIP_SYNTHESIS_API_KEY env var (do not store here)

[models.evaluation]
provider = "openai_compatible"
model = "google/gemma-3-4b-it"
base_url = "https://openrouter.ai/api"
# api_key = ""  # Set via env

[models.sexton]
provider = "openai_compatible"
model = "google/gemma-3-4b-it"
base_url = "https://openrouter.ai/api"
# api_key = ""  # Set via env

[models.embedding]
provider = "openai_compatible"
model = "text-embedding-3-small"
base_url = "https://openrouter.ai/api"
# api_key = ""  # Set via env

[models.beast]
provider = "openai_compatible"
model = "nvidia/nemotron-3-super-120b-a12b"
base_url = "https://openrouter.ai/api"
# api_key = ""  # Set via env

[definer]
# Path to DEFINER profile markdown file (relative to repo root).
# The profile provides personal context (identity, projects, communication prefs,
# theology, methodology) injected into every augmented chat system prompt.
profile_path = "examples/seed_corpus/definer_profile_v1.md"
# Whether to inject the DEFINER profile into augmented chat system prompts.
# Default true: every augmented session starts with DEFINER orientation.
inject_in_augmented_chat = true
# Approximate token budget for the profile block (rough 4 chars/token).
# Profile will be truncated with a note if it exceeds this.
max_profile_tokens = 800

# ---------------------------------------------------------------------------
# Sprint 5.25: Operator Alerting
# Lightweight webhook/email notifications for significant auto-tuning events.
# Disabled by default — enable and configure transports as needed.
# ---------------------------------------------------------------------------
[alerting]
enabled = false
# webhook_url = "https://hooks.slack.com/services/..."  # POST JSON alerts
# email_to = "ops@example.com"
# email_from = "aip-brain@example.com"
# smtp_host = "smtp.example.com"
# smtp_port = 587
# smtp_username = "aip-brain"           # Sprint 5.26: SMTP authentication
# smtp_password = ""                     # Prefer AIP_SMTP_PASSWORD env var
# smtp_use_tls = true                    # Sprint 5.26: TLS control (default true)
alert_on_quality_degradation = true
alert_on_pool_adjustment = true
alert_on_batch_reduction = true
min_alert_interval_seconds = 300   # Rate-limit: don't re-alert for 5 min
webhook_max_retries = 3            # Sprint 5.26: retry count for webhook
webhook_retry_base_delay_seconds = 1.0  # Sprint 5.26: exponential backoff base

# Sprint 5.29: Config-driven alert routing.
# Maps alert types to specific transports. When configured, only the listed
# transports are used for that alert type. When not configured (default),
# all enabled transports are used for all alert types.
# Transport options: "webhook", "email"
# [alerting.routes]
# batch_reduction = ["webhook"]                    # Webhook only for batch reductions
# quality_degradation = ["email", "webhook"]        # Both email and webhook for quality
# pool_adjustment = ["email"]                        # Email only for pool adjustments

# ---------------------------------------------------------------------------
# Sprint 5.26: Auto-Tuning Policy Engine
# Configurable thresholds for read pool auto-sizing and graph batch auto-tuning.
# Changes here are hot-reloadable — adjust behavior without restart.
# All values have safe ranges; invalid values are rejected with clear logging.
# ---------------------------------------------------------------------------
[auto_tuning_policy]
# Read pool auto-sizing policy
read_pool_exhaustion_threshold = 0.3      # Exhaustion rate > this triggers sizing
read_pool_auto_apply_consecutive = 5       # Consecutive observations before auto-apply
read_pool_auto_apply_max_increase = 4      # Max connections above configured
read_pool_auto_apply_max_pool = 12         # Absolute pool size cap
read_pool_auto_rollback_enabled = true     # Auto-rollback when exhaustion recovers
read_pool_auto_rollback_consecutive = 5    # Low-exhaustion observations before rollback
read_pool_auto_rollback_healthy = 0.15     # Exhaustion below this = healthy

# Graph extraction batch auto-tuning policy
graph_batch_decrease_threshold = 0.3       # Failure rate above → decrease
graph_batch_increase_threshold = 0.1        # Failure rate below → increase
graph_batch_auto_tune_window = 5           # Batches to consider
graph_batch_min_size = 1
graph_batch_max_size = 8

# Cooldown between auto-tuning adjustments (seconds)
cooldown_seconds = 60
